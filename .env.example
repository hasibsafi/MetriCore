# App
NODE_ENV=development

# Web
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-strong-secret
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_INTEGRATION_CLIENT_ID=replace-with-google-integration-client-id
GOOGLE_INTEGRATION_CLIENT_SECRET=replace-with-google-integration-client-secret
GOOGLE_OAUTH_STATE_SECRET=replace-with-64-char-hex
APP_URL=http://localhost:3000

# MailerSend
MAILERSEND_API_KEY=replace-with-mailersend-api-key
MAILERSEND_FROM_EMAIL=replace-with-verified-sender
MAILERSEND_FROM_NAME=MetriCore

# Services
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/metricore
REDIS_URL=redis://localhost:6379
PAGESPEED_API_KEY=replace-with-pagespeed-api-key

# Security
ENCRYPTION_KEY=replace-with-64-char-hex
