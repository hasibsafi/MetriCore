DATABASE_URL=postgresql://postgres:postgres@localhost:5433/metricore
REDIS_URL=redis://localhost:6379
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-strong-secret
AUTH_SECRET=replace-with-strong-secret
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
MAILERSEND_API_KEY=replace-with-mailersend-api-key
MAILERSEND_FROM_EMAIL=replace-with-verified-sender
MAILERSEND_FROM_NAME=MetriCore
MAILERSEND_SMTP_HOST=smtp.mailersend.net
MAILERSEND_SMTP_PORT=587
MAILERSEND_SMTP_USER=replace-with-smtp-username
MAILERSEND_SMTP_PASS=replace-with-smtp-password
MAILERSEND_SMTP_SECURE=false
